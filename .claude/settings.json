{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if echo \"$CLAUDE_FILE_PATH\" | grep -qE \"package-lock\\.json$|yarn\\.lock$|\\.env\"; then echo \"BLOCK: Do not edit lock files or .env files directly\" >&2; exit 2; fi'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(npm run build)",
      "Bash(npm test -- --watchAll=false)",
      "Bash(npm start)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)"
    ]
  }
}
